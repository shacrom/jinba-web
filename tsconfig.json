{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": { "@/*": ["src/*"] },
    "types": ["astro/client", "node"],
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true
  },
  "include": ["src", "tests", "scripts", "astro.config.mjs"]
}
