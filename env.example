# Jinba Web — Environment Variables
# Copy this file to .env and fill in the values.
# See README.md for full documentation.

# ─── Public (safe to expose in browser bundles) ─────────────────────────────

# Canonical site URL — used for canonical <link>, OG URLs, sitemap
PUBLIC_SITE_URL=https://jinba.example.com

# Supabase project URL (from Supabase dashboard → Project Settings → API)
PUBLIC_SUPABASE_URL=

# Supabase anon (public) key — safe for browser, row-level-security enforced
PUBLIC_SUPABASE_ANON_KEY=

# Plausible Analytics domain (optional — omit to disable analytics)
PUBLIC_PLAUSIBLE_DOMAIN=jinba.example.com

# Meilisearch public URL (optional — omit to disable search)
PUBLIC_MEILI_URL=

# Meilisearch public search key (optional — read-only, safe for browser)
PUBLIC_MEILI_PUBLIC_KEY=

# ─── Server-only (NEVER expose in client bundles) ───────────────────────────

# Supabase service role key — full admin access; server-side ONLY
SUPABASE_SERVICE_ROLE_KEY=

# Admin preview token — stop-gap F1 auth for /admin/* paths.
# The admin dashboard at /admin/scraping/ checks ?token=<this value>.
# Leave empty to fail-closed (all requests return 404). Rotate periodically.
ADMIN_PREVIEW_TOKEN=

# Path to jinba-db/types/database.ts for type sync (optional — defaults to ../jinba-db/types/database.ts)
JINBA_DB_PATH=../jinba-db/types/database.ts
