---
/**
 * PriceHistoryChart.astro — M4
 * Server-rendered SVG price-history chart. Two variants:
 *   - compact (800×240): rendered on model page below LivePriceStats
 *   - full    (1200×400): rendered on the dedicated /prices/ page
 * Zero runtime JS. Empty state when points.length < 3.
 * REQ-PH-03, REQ-PH-06.
 */
import type { Locale } from "@/i18n/config";
import { t } from "@/i18n/en";
import type { PricePoint } from "@/lib/price-history";
import { buildPriceHistorySVG } from "@/lib/price-history-svg";

export interface Props {
  points: PricePoint[];
  currency?: string;
  locale: Locale;
  variant?: "compact" | "full";
  ctaUrl?: string;
  className?: string;
}

const {
  points,
  currency = "EUR",
  locale,
  variant = "compact",
  ctaUrl,
  className = "",
} = Astro.props;
const tr = t(locale);

const isCompact = variant === "compact";
const width = isCompact ? 800 : 1200;
const height = isCompact ? 240 : 400;
const padding = isCompact
  ? { top: 16, right: 24, bottom: 36, left: 60 }
  : { top: 24, right: 40, bottom: 48, left: 80 };

const geo = buildPriceHistorySVG(points, { width, height, padding });

const fmt = new Intl.NumberFormat(locale === "es" ? "es-ES" : "en-US", {
  style: "currency",
  currency,
  maximumFractionDigits: 0,
});
const dateFmt = new Intl.DateTimeFormat(locale === "es" ? "es-ES" : "en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
const formatDate = (iso: string): string => dateFmt.format(new Date(iso));

const trendWord = geo
  ? geo.summary.direction === "up"
    ? tr("priceHistory.trend.up")
    : geo.summary.direction === "down"
      ? tr("priceHistory.trend.down")
      : tr("priceHistory.trend.flat")
  : "";

const ariaLabel = geo
  ? tr("priceHistory.ariaLabel")
      .replace("{first}", formatDate(geo.summary.first.date))
      .replace("{last}", formatDate(geo.summary.last.date))
      .replace("{from}", fmt.format(geo.summary.first.median))
      .replace("{to}", fmt.format(geo.summary.last.median))
      .replace("{direction}", trendWord)
  : tr("priceHistory.empty");

const fontSize = isCompact ? 11 : 13;
---
{geo ? (
  <figure class={`my-6 ${className}`}>
    <svg
      role="img"
      aria-label={ariaLabel}
      viewBox={`0 0 ${width} ${height}`}
      xmlns="http://www.w3.org/2000/svg"
      class="block h-auto w-full"
      preserveAspectRatio="xMidYMid meet"
    >
      <title>{ariaLabel}</title>
      {/* Grid lines */}
      {geo.yTicks.map((tick) => (
        <line
          x1={padding.left}
          x2={width - padding.right}
          y1={tick.y}
          y2={tick.y}
          stroke="var(--color-border)"
          stroke-width="1"
          stroke-dasharray="2 3"
          opacity="0.6"
        />
      ))}

      {/* p25–p75 band */}
      <path
        d={geo.bandPath}
        fill="var(--color-accent)"
        fill-opacity="0.18"
        stroke="none"
      />

      {/* Median line */}
      <path
        d={geo.medianPath}
        stroke="var(--color-accent)"
        stroke-width="2"
        fill="none"
        stroke-linecap="round"
        stroke-linejoin="round"
      />

      {/* Y-axis labels */}
      {geo.yTicks.map((tick) => (
        <text
          x={padding.left - 8}
          y={tick.y}
          text-anchor="end"
          dominant-baseline="middle"
          fill="var(--color-muted)"
          font-size={fontSize}
        >
          {fmt.format(tick.value)}
        </text>
      ))}

      {/* X-axis labels */}
      {geo.xTicks.map((tick) => (
        <text
          x={tick.x}
          y={height - padding.bottom + 16}
          text-anchor="middle"
          fill="var(--color-muted)"
          font-size={fontSize}
        >
          {formatDate(tick.rawDate)}
        </text>
      ))}
    </svg>

    <figcaption class="mt-3 flex flex-wrap items-center justify-between gap-2 text-sm">
      <span class="sr-only">{ariaLabel}</span>
      <span class="inline-flex items-center gap-3 text-xs text-[var(--color-muted)]">
        <span class="inline-flex items-center gap-1.5">
          <span class="inline-block h-0.5 w-4 bg-[var(--color-accent)]"></span>
          {tr("priceHistory.legend.median")}
        </span>
        <span class="inline-flex items-center gap-1.5">
          <span
            class="inline-block h-3 w-4 rounded-sm"
            style="background:var(--color-accent);opacity:0.18"
          ></span>
          {tr("priceHistory.legend.band")}
        </span>
      </span>
      {ctaUrl && isCompact && (
        <a
          href={ctaUrl}
          class="text-[var(--color-accent)] hover:underline focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
        >
          {tr("priceHistory.viewFull")} →
        </a>
      )}
    </figcaption>

    {/* Visually hidden data table for assistive tech */}
    <table class="sr-only">
      <caption>{tr("priceHistory.table.heading")}</caption>
      <thead>
        <tr>
          <th>{tr("priceHistory.table.date")}</th>
          <th>{tr("priceHistory.legend.median")}</th>
          <th>{tr("priceHistory.legend.band")}</th>
          <th>{tr("priceHistory.table.count")}</th>
        </tr>
      </thead>
      <tbody>
        {points.map((p) => (
          <tr>
            <td>{formatDate(p.date)}</td>
            <td>{fmt.format(p.median)}</td>
            <td>{fmt.format(p.p25)} – {fmt.format(p.p75)}</td>
            <td>{p.count}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </figure>
) : (
  <div class={`my-6 ${className}`}>
    <p class="text-sm text-[var(--color-muted)]">{tr("priceHistory.empty")}</p>
    {ctaUrl && isCompact && (
      <p class="mt-2 text-sm">
        <a
          href={ctaUrl}
          class="text-[var(--color-accent)] hover:underline focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
        >
          {tr("priceHistory.viewFull")} →
        </a>
      </p>
    )}
  </div>
)}
