---
/**
 * TocSidebar.astro — T20
 * Desktop sticky table of contents. Pure server-rendered, no JS.
 * REQ-TOC-01, REQ-TOC-05.
 */
import type { Locale } from "@/i18n/config";
import { t } from "@/i18n/en";

export interface Props {
  sections: Array<{ id: string; title: string }>;
  locale: Locale;
}

const { sections, locale } = Astro.props;
const tr = t(locale);
---

<nav
  aria-label={tr("model.toc.open")}
  class="sticky top-20 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-card)] p-4"
>
  <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-[var(--color-muted)]">
    {tr("model.toc.open")}
  </p>
  <ul class="space-y-1">
    {sections.map((s) => (
      <li>
        <a
          href={`#${s.id}`}
          class="block rounded-[var(--radius-sm)] px-2 py-1.5 text-sm text-[var(--color-fg)] transition-colors hover:bg-[var(--color-border)] hover:text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
        >
          {s.title}
        </a>
      </li>
    ))}
  </ul>
</nav>
