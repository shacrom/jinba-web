---
import { adminT } from "@/i18n/admin";
import { type ScrapeRunRow, formatDuration, formatRelative } from "@/lib/admin-scraping-format";

export type RunRow = ScrapeRunRow & { source_slug: string };

export interface Props {
  rows: RunRow[];
}

const { rows } = Astro.props;
---

<section id="runs" aria-labelledby="runs-heading">
  <h2 id="runs-heading" class="mb-3 text-xl font-semibold">
    {adminT("runs.heading")}
  </h2>
  <div class="overflow-x-auto rounded-[var(--radius)] border border-[var(--color-border)]">
    <table class="min-w-full text-sm">
      <caption class="sr-only">{adminT("runs.caption")}</caption>
      <thead class="bg-[var(--color-card)] text-xs uppercase text-[var(--color-muted)]">
        <tr>
          <th scope="col" class="px-3 py-2 text-left">{adminT("runs.col.source")}</th>
          <th scope="col" class="px-3 py-2 text-left">{adminT("runs.col.started")}</th>
          <th scope="col" class="px-3 py-2 text-left">{adminT("runs.col.finished")}</th>
          <th scope="col" class="px-3 py-2 text-left">{adminT("runs.col.duration")}</th>
          <th scope="col" class="px-3 py-2 text-right">{adminT("runs.col.found")}</th>
          <th scope="col" class="px-3 py-2 text-right">{adminT("runs.col.new")}</th>
          <th scope="col" class="px-3 py-2 text-right">{adminT("runs.col.updated")}</th>
          <th scope="col" class="px-3 py-2 text-right">{adminT("runs.col.errored")}</th>
        </tr>
      </thead>
      <tbody>
        {
          rows.length === 0 && (
            <tr>
              <td
                colspan="8"
                class="px-3 py-4 text-center text-[var(--color-muted)]"
              >
                {adminT("runs.row.empty")}
              </td>
            </tr>
          )
        }
        {
          rows.map((r) => (
            <tr class="border-t border-[var(--color-border)]">
              <td class="px-3 py-2 font-mono text-xs">{r.source_slug}</td>
              <td class="px-3 py-2">{formatRelative(r.started_at)}</td>
              <td class="px-3 py-2">
                {r.finished_at ? (
                  formatRelative(r.finished_at)
                ) : (
                  <em class="text-[var(--color-accent)]">
                    {adminT("runs.status.inProgress")}
                  </em>
                )}
              </td>
              <td class="px-3 py-2">{formatDuration(r.duration_ms)}</td>
              <td class="px-3 py-2 text-right">{r.items_found}</td>
              <td class="px-3 py-2 text-right">{r.items_new}</td>
              <td class="px-3 py-2 text-right">{r.items_updated}</td>
              <td
                class={`px-3 py-2 text-right ${r.items_errored > 0 ? "text-[var(--color-accent-hot)]" : ""}`}
              >
                {r.items_errored}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>
