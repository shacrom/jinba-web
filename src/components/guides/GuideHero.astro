---
/**
 * GuideHero.astro — M6 T12
 * Detail banner with serif title, author, date, reading time.
 * Uses cover_image as background layer when present; otherwise a dark
 * gradient keeps the layout stable.
 * REQ-DETAIL-02, REQ-DETAIL-05, REQ-A11Y-02.
 */
import type { CollectionEntry } from "astro:content";
import type { Locale } from "@/i18n/config";
import { t } from "@/i18n/en";

export interface Props {
  entry: CollectionEntry<"guides">;
  locale: Locale;
  minutes: number;
}

const { entry, locale, minutes } = Astro.props;
const tr = t(locale);

const dateFmt = new Intl.DateTimeFormat(locale === "es" ? "es-ES" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const cover = entry.data.cover_image ?? entry.data.cover;
const dateLabel = tr("guides.detail.publishedOn").replace(
  "{date}",
  dateFmt.format(entry.data.publishedAt)
);
const readingLabel = tr("guides.detail.readingTimeMin").replace("{min}", String(minutes));
const authorLabel = entry.data.author
  ? tr("guides.detail.byAuthor").replace("{author}", entry.data.author)
  : null;
---

<section class="relative overflow-hidden rounded-[var(--radius-lg)] bg-[var(--color-card)] shadow-[var(--shadow-card)]">
  <div class="aspect-[21/9]">
    {
      cover ? (
        <img
          src={cover}
          alt=""
          class="h-full w-full object-cover"
          loading="eager"
          fetchpriority="high"
          width="1680"
          height="720"
        />
      ) : (
        <div
          class="h-full w-full bg-gradient-to-br from-[var(--color-card)] via-[var(--color-bg)] to-[var(--color-card)]"
          aria-hidden="true"
        />
      )
    }
  </div>
  <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-6 md:p-8">
    {
      entry.data.tags.length > 0 && (
        <p class="text-xs font-medium uppercase tracking-widest text-[var(--color-accent)]">
          {entry.data.tags.join(" · ")}
        </p>
      )
    }
    <h1 class="mt-2 font-serif text-3xl font-semibold text-white md:text-5xl">
      {entry.data.title}
    </h1>
    <p class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-white/80">
      <span>{dateLabel}</span>
      <span aria-hidden="true">·</span>
      <span>{readingLabel}</span>
      {
        authorLabel && (
          <>
            <span aria-hidden="true">·</span>
            <span>{authorLabel}</span>
          </>
        )
      }
    </p>
  </div>
</section>
