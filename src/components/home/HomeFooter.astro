---
/**
 * HomeFooter.astro — T07
 * Shared Home footer with legal/imagery links and language switcher.
 * REQ-LAYOUT-02.
 */
import type { Locale } from "@/i18n/config";
import { t } from "@/i18n/en";

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const tr = t(locale);
const alt: Locale = locale === "es" ? "en" : "es";
const legalPath = locale === "es" ? "/es/legal" : "/en/legal";
const imageryPath = locale === "es" ? "/es/legal/imagenes" : "/en/legal/imagery";
---

<footer class="border-t border-[var(--color-border)]">
  <div
    class="mx-auto flex max-w-6xl flex-wrap items-center gap-4 px-6 py-10 text-xs text-[var(--color-muted)]"
  >
    <a
      href={legalPath}
      class="underline underline-offset-2 transition-colors hover:text-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
    >
      {tr("footer.legal")}
    </a>
    <span aria-hidden="true">·</span>
    <a
      href={imageryPath}
      class="underline underline-offset-2 transition-colors hover:text-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
    >
      {tr("footer.imagery")}
    </a>
    <span aria-hidden="true">·</span>
    <a
      href={`/${locale}/privacy`}
      class="underline underline-offset-2 transition-colors hover:text-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
    >
      {tr("footer.privacy")}
    </a>
    <span aria-hidden="true">·</span>
    <a
      href={`/${locale}/guides/`}
      class="underline underline-offset-2 transition-colors hover:text-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
    >
      {tr("nav.guides")}
    </a>
    <span aria-hidden="true">·</span>
    <a
      href={`/${alt}/`}
      hreflang={alt}
      class="transition-colors hover:text-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
    >
      {alt.toUpperCase()}
    </a>
  </div>
</footer>
