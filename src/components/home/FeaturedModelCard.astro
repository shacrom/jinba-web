---
/**
 * FeaturedModelCard.astro — T08
 * Anchor card for a generation, linking to /{lang}/{make}/{model}/{gen}/.
 * REQ-MODELS-03/04.
 */
import type { Locale } from "@/i18n/config";

export interface Props {
  makeSlug: string;
  modelSlug: string;
  genSlug: string;
  makeName: string;
  modelName: string;
  genName: string;
  yearStart: number;
  yearEnd?: number | null;
  chassisCode?: string | null;
  locale: Locale;
}

const {
  makeSlug,
  modelSlug,
  genSlug,
  makeName,
  modelName,
  genName,
  yearStart,
  yearEnd,
  chassisCode,
  locale,
} = Astro.props;

const href = `/${locale}/${makeSlug}/${modelSlug}/${genSlug}/`;
const years = `${yearStart}${yearEnd ? `–${yearEnd}` : ""}`;
const ariaLabel = `${makeName} ${modelName} ${genName}`;
---

<a
  href={href}
  aria-label={ariaLabel}
  class="group block rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-card)] p-5 transition-shadow hover:shadow-[var(--shadow-card)] hover:ring-2 hover:ring-[var(--color-ring)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
>
  <p class="text-xs uppercase tracking-widest text-[var(--color-accent)]">
    {makeName}
  </p>
  <p class="mt-1 text-xl font-semibold text-[var(--color-fg)]">
    {modelName} {genName}
  </p>
  <p class="mt-1 text-sm text-[var(--color-muted)]">
    {years}
    {
      chassisCode && (
        <span class="ml-2 inline-block rounded border border-[var(--color-border)] px-1.5 py-0.5 text-[10px] uppercase">
          {chassisCode}
        </span>
      )
    }
  </p>
</a>
