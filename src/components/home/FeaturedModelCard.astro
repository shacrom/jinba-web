---
/**
 * FeaturedModelCard.astro — T08
 * Anchor card for a generation, linking to /{lang}/{make}/{model}/{gen}/.
 * REQ-MODELS-03/04.
 */
import { getModelHero } from "@/data/model-heroes";
import type { Locale } from "@/i18n/config";

export interface Props {
  makeSlug: string;
  modelSlug: string;
  genSlug: string;
  makeName: string;
  modelName: string;
  genName: string;
  yearStart: number;
  yearEnd?: number | null;
  chassisCode?: string | null;
  locale: Locale;
}

const {
  makeSlug,
  modelSlug,
  genSlug,
  makeName,
  modelName,
  genName,
  yearStart,
  yearEnd,
  chassisCode,
  locale,
} = Astro.props;

const href = `/${locale}/${makeSlug}/${modelSlug}/${genSlug}/`;
const years = `${yearStart}${yearEnd ? `–${yearEnd}` : ""}`;
const ariaLabel = `${makeName} ${modelName} ${genName}`;

// Pull the editorial thumbnail from the registry (same source of truth as the
// model detail hero). No network query — lookup is O(1) in a static Record.
const hero = getModelHero(makeSlug, modelSlug, genSlug);
---

<a
  href={href}
  aria-label={ariaLabel}
  class="group block overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-card)] transition-shadow hover:shadow-[var(--shadow-card)] hover:ring-2 hover:ring-[var(--color-ring)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
>
  {
    hero ? (
      <div class="aspect-[4/3] overflow-hidden bg-[var(--color-bg)]">
        <img
          src={hero.thumb}
          alt={hero.alt}
          width={640}
          height={480}
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
        />
      </div>
    ) : (
      <div class="aspect-[4/3] bg-[var(--color-bg)]" aria-hidden="true" />
    )
  }

  <div class="p-5">
    <p class="text-xs uppercase tracking-widest text-[var(--color-accent)]">
      {makeName}
    </p>
    <p class="mt-1 text-xl font-semibold text-[var(--color-fg)]">
      {modelName} {genName}
    </p>
    <p class="mt-1 text-sm text-[var(--color-muted)]">
      {years}
      {
        chassisCode && (
          <span class="ml-2 inline-block rounded border border-[var(--color-border)] px-1.5 py-0.5 text-[10px] uppercase">
            {chassisCode}
          </span>
        )
      }
    </p>
  </div>
</a>
