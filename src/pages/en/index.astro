---
import EmailSignupForm from "@/components/islands/EmailSignupForm.tsx";
import ThemeToggle from "@/components/islands/ThemeToggle.tsx";
import { t } from "@/i18n/en";
import BaseLayout from "@/layouts/BaseLayout.astro";

const tr = t("en");
---

<BaseLayout
  title={tr("home.title")}
  description={tr("home.subtitle")}
  locale="en"
  path="/en/"
>
  <main class="mx-auto flex min-h-screen max-w-3xl flex-col gap-12 px-6 py-10">
    <header class="flex items-center justify-between">
      <a href="/en/" aria-label="Jinba home">
        <strong class="text-xl tracking-tight text-[var(--color-fg)]">Jinba</strong>
      </a>
      <nav aria-label="Main navigation" class="flex items-center gap-4">
        <a
          href="/en/"
          class="text-sm text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors"
        >
          {tr("nav.home")}
        </a>
        <a
          href="/en/models"
          class="text-sm text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors"
        >
          {tr("nav.models")}
        </a>
        <a
          href="/en/guides"
          class="text-sm text-[var(--color-muted)] hover:text-[var(--color-fg)] transition-colors"
        >
          {tr("nav.guides")}
        </a>
        <ThemeToggle
          client:idle
          label={tr("theme.toggle")}
          labelLight={tr("theme.labelLight")}
          labelDark={tr("theme.labelDark")}
        />
      </nav>
    </header>

    <section class="flex flex-1 flex-col justify-center gap-6 py-16">
      <h1 class="text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">
        {tr("home.title")}
      </h1>
      <p class="max-w-lg text-lg text-[var(--color-muted)]">
        {tr("home.subtitle")}
      </p>
      <div class="pt-2">
        <EmailSignupForm
          client:visible
          placeholder={tr("home.cta.placeholder")}
          submit={tr("home.cta.signup")}
          errorMessage={tr("form.error.invalidEmail")}
          successMessage={tr("form.success.signup")}
        />
      </div>
    </section>

    <footer class="flex items-center gap-4 pt-4 text-xs text-[var(--color-muted)]">
      <a
        href="/en/legal"
        class="underline underline-offset-2 hover:text-[var(--color-fg)] transition-colors"
      >
        {tr("footer.legal")}
      </a>
      <span aria-hidden="true">·</span>
      <a
        href="/en/legal/imagery"
        class="underline underline-offset-2 hover:text-[var(--color-fg)] transition-colors"
      >
        {tr("footer.imagery")}
      </a>
      <span aria-hidden="true">·</span>
      <a href="/es/" hreflang="es" class="hover:text-[var(--color-fg)] transition-colors">ES</a>
    </footer>
  </main>
</BaseLayout>
