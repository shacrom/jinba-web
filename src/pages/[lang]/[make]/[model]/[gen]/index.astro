---
import { getCollection, render } from "astro:content";
/**
 * src/pages/[lang]/[make]/[model]/[gen]/index.astro — T27
 * Static model page route. getStaticPaths() generates 10 paths (5 gens × 2 locales).
 * Falls back to taxonomy-seed.json when Supabase returns 0 rows (CI / no DB).
 * REQ-ROUTE-01 through REQ-ROUTE-04, SC-10.
 * M4 (T09): compact price-history chart rendered after LivePriceStats.
 */
import HomeNav from "@/components/home/HomeNav.astro";
import UserActionsIsland from "@/components/islands/UserActionsIsland.tsx";
import CommonFaultsTable from "@/components/model/CommonFaultsTable.astro";
import LivePriceStats from "@/components/model/LivePriceStats.astro";
import TrimFilter from "@/components/model/TrimFilter.astro";
import ModelFooter from "@/components/model/ModelFooter.astro";
import ModelHero from "@/components/model/ModelHero.astro";
import ModificationsList from "@/components/model/ModificationsList.astro";
import PriceHistoryChart from "@/components/model/PriceHistoryChart.astro";
import RelatedListingsStrip from "@/components/model/RelatedListingsStrip.astro";
import SpecBand from "@/components/model/SpecBand.astro";
import TocSidebar from "@/components/model/TocSidebar.astro";
import TocSidebarMobile from "@/components/model/TocSidebarMobile.tsx";
import { getModelHero } from "@/data/model-heroes";
import type { Locale } from "@/i18n/config";
import { t } from "@/i18n/en";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildCarJsonLd } from "@/lib/jsonld";
import type { FaultEntry, HeroImage, ModEntry, SiblingGen, TrimDisplay } from "@/lib/model-types";
import { getPriceHistory } from "@/lib/price-history";
import { supabase } from "@/lib/supabase";

// ── Types ──────────────────────────────────────────────────────────────────

interface GenTaxonomy {
  id: number;
  slug: string;
  name_es: string;
  name_en: string;
  year_start: number;
  year_end: number | null;
  chassis_code: string | null;
  models: {
    id: number;
    slug: string;
    name_es: string;
    name_en: string;
    makes: {
      id: number;
      slug: string;
      name_es: string;
      name_en: string;
    };
  };
  trims: Array<{
    id: number;
    slug: string;
    name_es: string;
    name_en: string;
    power_hp: number | null;
    engine_code: string | null;
  }>;
}

interface SeedEntry {
  make: string;
  model: string;
  gen: string;
  // Optional rich fields — when present, override the generic fallback defaults.
  make_name_es?: string;
  make_name_en?: string;
  model_name_es?: string;
  model_name_en?: string;
  gen_name_es?: string;
  gen_name_en?: string;
  chassis_code?: string;
  year_start?: number;
  year_end?: number;
  trims?: Array<{
    slug: string;
    name_es: string;
    name_en: string;
    power_hp: number | null;
    engine_code: string | null;
  }>;
}

// ── getStaticPaths ─────────────────────────────────────────────────────────

export async function getStaticPaths() {
  // Inline helpers — must live inside getStaticPaths because Astro compiles it
  // in a separate module chunk where frontmatter-scope helpers are not available.
  const { readFileSync } = await import("node:fs");
  const { resolve } = await import("node:path");
  const { supabase: sb } = await import("@/lib/supabase");

  function readSeed(): SeedEntry[] {
    try {
      const p = resolve("scripts/data/taxonomy-seed.json");
      return JSON.parse(readFileSync(p, "utf8")) as SeedEntry[];
    } catch {
      return [];
    }
  }

  function seedEntryToGenTaxonomy(entry: SeedEntry, idBase: number): GenTaxonomy {
    return {
      id: idBase,
      slug: entry.gen,
      name_es: entry.gen_name_es ?? entry.gen.toUpperCase(),
      name_en: entry.gen_name_en ?? entry.gen.toUpperCase(),
      year_start: entry.year_start ?? 1980,
      year_end: entry.year_end ?? null,
      chassis_code: entry.chassis_code ?? null,
      models: {
        id: idBase + 1,
        slug: entry.model,
        name_es: entry.model_name_es ?? entry.model,
        name_en: entry.model_name_en ?? entry.model,
        makes: {
          id: idBase + 2,
          slug: entry.make,
          name_es: entry.make_name_es ?? entry.make,
          name_en: entry.make_name_en ?? entry.make,
        },
      },
      trims: (entry.trims ?? []).map((t, i) => ({
        id: idBase + 10 + i,
        slug: t.slug,
        name_es: t.name_es,
        name_en: t.name_en,
        power_hp: t.power_hp,
        engine_code: t.engine_code,
      })),
    };
  }

  function buildFallbackPaths(
    seed: SeedEntry[]
  ): Array<{ params: Record<string, string>; props: { g: GenTaxonomy; lang: Locale } }> {
    const paths: Array<{
      params: Record<string, string>;
      props: { g: GenTaxonomy; lang: Locale };
    }> = [];
    let idCounter = 1;
    for (const entry of seed) {
      const g = seedEntryToGenTaxonomy(entry, idCounter);
      idCounter += 100;
      for (const lang of ["es", "en"] as Locale[]) {
        paths.push({
          params: { lang, make: entry.make, model: entry.model, gen: entry.gen },
          props: { g, lang },
        });
      }
    }
    return paths;
  }

  let rows: GenTaxonomy[] = [];

  if (sb) {
    try {
      const { data, error } = await sb.from("generations").select(`
          id, slug, name_es, name_en, year_start, year_end, chassis_code,
          models!inner (
            id, slug, name_es, name_en,
            makes!inner ( id, slug, name_es, name_en )
          ),
          trims ( id, slug, name_es, name_en, power_hp, engine_code )
        `);

      if (!error && data && data.length > 0) {
        rows = data as unknown as GenTaxonomy[];
      }
    } catch {
      // Supabase unavailable — fall through to seed
    }
  }

  if (rows.length > 0) {
    // Merge seed entries that are NOT already represented in Supabase rows.
    // This lets taxonomy-seed.json act as a supplement to the DB — useful for
    // content-only additions that don't require a DB write.
    const existingKeys = new Set(
      rows.map((r) => `${r.models?.makes?.slug}/${r.models?.slug}/${r.slug}`)
    );
    const seed = readSeed();
    let seedIdCounter = 100_000; // offset to avoid collisions with DB ids
    for (const entry of seed) {
      const key = `${entry.make}/${entry.model}/${entry.gen}`;
      if (!existingKeys.has(key)) {
        rows.push(seedEntryToGenTaxonomy(entry, seedIdCounter));
        seedIdCounter += 100;
      }
    }

    const paths: Array<{
      params: Record<string, string>;
      props: { g: GenTaxonomy; lang: Locale };
    }> = [];
    for (const g of rows) {
      if (!g.models?.makes) continue;
      for (const lang of ["es", "en"] as Locale[]) {
        paths.push({
          params: { lang, make: g.models.makes.slug, model: g.models.slug, gen: g.slug },
          props: { g, lang },
        });
      }
    }
    return paths;
  }

  // CI fallback: use taxonomy-seed.json
  const seed = readSeed();
  return buildFallbackPaths(seed);
}

// ── Page data ──────────────────────────────────────────────────────────────

const { g, lang } = Astro.props as { g: GenTaxonomy; lang: Locale };
const tr = t(lang);

function name(x: { name_es: string; name_en: string }): string {
  return lang === "es" ? x.name_es : x.name_en;
}

const makeName = name(g.models.makes);
const modelName = name(g.models);
const genName = name(g);

const path = `/${lang}/${g.models.makes.slug}/${g.models.slug}/${g.slug}/`;
const title = tr("seo.modelPageTitle").replace("{gen}", `${makeName} ${modelName} ${genName}`);
const description = `${makeName} ${modelName} ${genName} (${g.year_start}${g.year_end ? `–${g.year_end}` : ""}): ${tr("model.toc.buying_guide")}, ${tr("model.toc.common_faults")}, ${tr("model.toc.modifications")}.`;

// Hero image resolution order (first hit wins):
//   1. Editorial registry in src/data/model-heroes.ts (self-hosted, attributed).
//   2. First privacy-processed listing photo from Supabase.
//   3. Static placeholder in the ModelHero component.
let heroImage: HeroImage | null = null;
const editorialHero = getModelHero(g.models.makes.slug, g.models.slug, g.slug);
if (editorialHero) {
  heroImage = {
    url: editorialHero.image,
    width: editorialHero.width,
    height: editorialHero.height,
    alt: editorialHero.alt,
    credit: editorialHero.credit,
    credit_url: editorialHero.source_url,
  };
} else if (supabase) {
  try {
    const { data: heroRows } = await supabase
      .from("listings_public")
      .select("id, listing_photos!inner(storage_path, width, height, privacy_processed_at)")
      .eq("generation_id", g.id)
      .eq("status", "active")
      .not("listing_photos.privacy_processed_at", "is", null)
      .limit(1);

    const photo = (heroRows?.[0] as Record<string, unknown> | undefined)?.listing_photos as
      | Array<{ storage_path: string | null; width: number | null; height: number | null }>
      | undefined;
    const firstPhoto = photo?.[0];
    if (firstPhoto?.storage_path) {
      const base = import.meta.env.PUBLIC_SUPABASE_URL as string;
      heroImage = {
        url: `${base}/storage/v1/object/public/listing-photos/${firstPhoto.storage_path}`,
        width: firstPhoto.width ?? 1200,
        height: firstPhoto.height ?? 675,
        alt: `${makeName} ${modelName} ${genName}`,
      };
    }
  } catch {
    // No hero — placeholder used
  }
}

// Editorial MDX sections
// Astro 6 glob loader slugifies filename segments (strips dots), so `getEntry("models", ".../overview.es")`
// fails. We resolve entries via `getCollection("models")` + frontmatter fields instead.
const allModelEntries = await getCollection("models");
const findSection = (section: "overview" | "buying-guide" | "common-faults" | "modifications") =>
  allModelEntries.find(
    (e) =>
      e.data.make === g.models.makes.slug &&
      e.data.model === g.models.slug &&
      e.data.generation === g.slug &&
      e.data.locale === lang &&
      e.data.section === section
  );
const overviewEntry = findSection("overview");
const buyingEntry = findSection("buying-guide");
const faultsEntry = findSection("common-faults");
const modsEntry = findSection("modifications");

// Astro 6 API: `render(entry)` returns the renderable Content component.
const OverviewContent = overviewEntry ? (await render(overviewEntry)).Content : null;
const BuyingContent = buyingEntry ? (await render(buyingEntry)).Content : null;
const FaultsContent = faultsEntry ? (await render(faultsEntry)).Content : null;
const ModsContent = modsEntry ? (await render(modsEntry)).Content : null;

// Fault + mod structured data
const allFaults = await getCollection("modelFaults");
const faults: FaultEntry[] = allFaults
  .filter(
    (e) =>
      e.data.make === g.models.makes.slug &&
      e.data.model === g.models.slug &&
      e.data.gen === g.slug &&
      e.data.locale === lang
  )
  .map((e) => e.data as unknown as FaultEntry);

const allMods = await getCollection("modelMods");
const mods: ModEntry[] = allMods
  .filter(
    (e) =>
      e.data.make === g.models.makes.slug &&
      e.data.model === g.models.slug &&
      e.data.gen === g.slug &&
      e.data.locale === lang
  )
  .map((e) => e.data as unknown as ModEntry);

// Sibling generations (same model, different gen)
let siblings: SiblingGen[] = [];
if (supabase) {
  try {
    const { data: siblingRows } = await supabase
      .from("generations")
      .select("slug, name_es, name_en, year_start, year_end, models!inner(slug, makes!inner(slug))")
      .eq("model_id", g.models.id)
      .neq("id", g.id);

    siblings = (siblingRows ?? []).map((s: Record<string, unknown>) => {
      const sibling = s as {
        slug: string;
        name_es: string;
        name_en: string;
        year_start: number;
        year_end: number | null;
        models: { slug: string; makes: { slug: string } };
      };
      const sName = lang === "es" ? sibling.name_es : sibling.name_en;
      const years = `${sibling.year_start}${sibling.year_end ? `–${sibling.year_end}` : ""}`;
      return {
        url: `/${lang}/${sibling.models.makes.slug}/${sibling.models.slug}/${sibling.slug}/`,
        name: sName,
        years,
      };
    });
  } catch {
    // No siblings on CI
  }
}

// Trims display
const trims: TrimDisplay[] = (g.trims ?? []).map((trim) => ({
  name: lang === "es" ? trim.name_es : trim.name_en,
  powerHp: trim.power_hp,
  engineCode: trim.engine_code,
}));

// JSON-LD
const jsonLd = buildCarJsonLd({
  makeName,
  modelName,
  genName,
  years: { start: g.year_start, end: g.year_end ?? undefined },
  chassisCode: g.chassis_code ?? undefined,
  description,
  url: new URL(
    path,
    (import.meta.env.PUBLIC_SITE_URL as string | undefined) ?? "https://jinba.example.com"
  ).toString(),
  image: heroImage?.url,
});

const sections = [
  { id: "overview", title: tr("model.toc.overview") },
  { id: "buying-guide", title: tr("model.toc.buying_guide") },
  { id: "common-faults", title: tr("model.toc.common_faults") },
  { id: "modifications", title: tr("model.toc.modifications") },
];

// M4: compact price-history chart after LivePriceStats — REQ-PH-04.
const historyPoints = await getPriceHistory({
  generationId: g.id,
  currency: "EUR",
  windowDays: 365,
});
const pricesUrl = `/${lang}/${g.models.makes.slug}/${g.models.slug}/${g.slug}/prices/`;

const ogImage =
  heroImage?.url ??
  new URL(
    "/placeholders/model-hero.webp",
    (import.meta.env.PUBLIC_SITE_URL as string | undefined) ?? "https://jinba.example.com"
  ).toString();
---

<BaseLayout
  title={title}
  description={description}
  locale={lang}
  path={path}
  image={ogImage}
  jsonLd={jsonLd}
>

  <HomeNav locale={lang} />

  <main class="mx-auto max-w-6xl px-4 pb-16">
    {/* Breadcrumb (REQ-SEO-01, visible nav) */}
    <nav aria-label="breadcrumb" class="py-4 text-sm text-[var(--color-muted)]">
      <ol class="flex flex-wrap items-center gap-1">
        <li><a href={`/${lang}/`} class="hover:text-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]">{tr("nav.home")}</a></li>
        <li aria-hidden="true">›</li>
        <li><a href={`/${lang}/${g.models.makes.slug}/`} class="hover:text-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]">{makeName}</a></li>
        <li aria-hidden="true">›</li>
        <li><a href={`/${lang}/${g.models.makes.slug}/${g.models.slug}/`} class="hover:text-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]">{modelName}</a></li>
        <li aria-hidden="true">›</li>
        <li><span aria-current="page">{genName}</span></li>
      </ol>
    </nav>

    {/* Hero */}
    <ModelHero
      make={{ id: g.models.makes.id, slug: g.models.makes.slug, name_es: g.models.makes.name_es, name_en: g.models.makes.name_en, name: makeName }}
      model={{ id: g.models.id, slug: g.models.slug, name_es: g.models.name_es, name_en: g.models.name_en, name: modelName }}
      gen={{ id: g.id, slug: g.slug, name_es: g.name_es, name_en: g.name_en, name: genName }}
      chassisCode={g.chassis_code}
      years={{ start: g.year_start, end: g.year_end ?? undefined }}
      heroImage={heroImage}
      locale={lang}
    />

    {/* Spec band */}
    <SpecBand trims={trims} locale={lang} />

    {/* User actions: sign-in / garage / watchlist — F2 */}
    <div class="mt-4">
      <UserActionsIsland
        client:idle
        generationId={g.id}
        locale={lang}
        labels={{
          signInPrompt: tr("model.actions.sign_in_prompt"),
          addGarage: tr("model.actions.add_garage"),
          inGarage: tr("model.actions.in_garage"),
          watch: tr("model.actions.watch"),
          watching: tr("model.actions.watching"),
        }}
      />
    </div>

    {/* Two-column layout: TOC sidebar (lg) + article */}
    <div class="mt-8 grid gap-8 lg:grid-cols-[18rem_minmax(0,1fr)]">
      {/* Desktop TOC */}
      <aside class="hidden lg:block">
        <TocSidebar sections={sections} locale={lang} />
      </aside>

      {/* Mobile TOC island */}
      <div class="lg:hidden">
        <TocSidebarMobile
          client:idle
          sections={sections}
          labels={{ open: tr("model.toc.open"), close: tr("model.toc.close") }}
        />
      </div>

      {/* Article — plain vertical flow, no magazine typography */}
      <article class="max-w-none space-y-12 lg:col-start-2 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h2]:mb-4 [&_h3]:text-base [&_h3]:font-semibold [&_h3]:tracking-tight [&_h3]:mt-6 [&_h3]:mb-2 [&_p]:mt-2 [&_p]:leading-relaxed [&_ul]:mt-2 [&_ul]:space-y-1 [&_ul]:list-disc [&_ul]:pl-5 [&_ul_li]:leading-relaxed [&_strong]:font-semibold [&_strong]:text-[var(--color-fg)]">

        {/* Overview */}
        <section id="overview" aria-labelledby="overview-heading">
          <h2 id="overview-heading">{tr("model.toc.overview")}</h2>
          {OverviewContent ? (
            <OverviewContent />
          ) : (
            <p class="text-[var(--color-muted)] italic">{tr("section.comingSoon")}</p>
          )}
          <LivePriceStats generationId={g.id} locale={lang} />
          <PriceHistoryChart
            points={historyPoints}
            currency="EUR"
            locale={lang}
            variant="compact"
            ctaUrl={pricesUrl}
          />
          {/* M5: Calculator CTA — REQ-CALC-ROUTE-03. */}
          <aside
            class="mt-4 rounded-[var(--radius)] border border-[var(--color-border)] bg-[var(--color-card)] p-4 not-prose"
            aria-labelledby="calc-cta-heading"
          >
            <p id="calc-cta-heading" class="text-sm font-medium text-[var(--color-fg)]">{tr("calc.cta.model")}</p>
            <p class="mt-1 text-xs text-[var(--color-muted)]">{tr("calc.cta.modelBody")}</p>
            <a
              href={`/${lang}/calculator/?make=${g.models.makes.slug}&model=${g.models.slug}&gen=${g.slug}`}
              class="mt-3 inline-block rounded-[var(--radius)] bg-[var(--color-accent)] px-3 py-1.5 text-xs font-medium text-[var(--color-accent-fg)] no-underline hover:bg-[var(--color-accent-hot)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-ring)]"
            >
              {tr("calc.cta.modelCtaLabel")}
            </a>
          </aside>
        </section>

        {/* Buying guide */}
        <section id="buying-guide" aria-labelledby="buying-guide-heading">
          <h2 id="buying-guide-heading">{tr("model.toc.buying_guide")}</h2>
          {BuyingContent ? (
            <BuyingContent />
          ) : (
            <p class="text-[var(--color-muted)] italic">{tr("section.comingSoon")}</p>
          )}
        </section>

        {/* Common faults */}
        <section id="common-faults" aria-labelledby="common-faults-heading">
          <h2 id="common-faults-heading">{tr("model.toc.common_faults")}</h2>
          {FaultsContent ? (
            <FaultsContent />
          ) : (
            <p class="text-[var(--color-muted)] italic">{tr("section.comingSoon")}</p>
          )}
          {/* Shared trim pill bar — also filters the mods section below. */}
          <TrimFilter
            trims={trims.map((t) => ({ name: t.name, engineCode: t.engineCode }))}
            locale={lang}
          />
          <CommonFaultsTable faults={faults} locale={lang} />
        </section>

        {/* Modifications */}
        <section id="modifications" aria-labelledby="modifications-heading">
          <h2 id="modifications-heading">{tr("model.toc.modifications")}</h2>
          {ModsContent ? (
            <ModsContent />
          ) : (
            <p class="text-[var(--color-muted)] italic">{tr("section.comingSoon")}</p>
          )}
          <ModificationsList mods={mods} locale={lang} />
        </section>

        {/* Related listings */}
        <RelatedListingsStrip
          generationId={g.id}
          limit={3}
          locale={lang}
          makeSlug={g.models.makes.slug}
          modelSlug={g.models.slug}
          genSlug={g.slug}
        />

      </article>
    </div>

    {/* Footer cross-links */}
    <ModelFooter siblings={siblings} locale={lang} />
  </main>
</BaseLayout>
