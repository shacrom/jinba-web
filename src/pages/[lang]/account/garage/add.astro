---
/**
 * src/pages/[lang]/account/garage/add.astro — F2 Batch 4 + OCR tab
 * Form to add a car to the user's garage. GET: render form. POST: insert.
 * Tab switcher: "Fill manually" (default) | "From vehicle registration" (OCR).
 */
export const prerender = false;

import HomeNav from "@/components/home/HomeNav.astro";
import FichaTecnicaUpload from "@/components/islands/FichaTecnicaUpload";
import type { Locale } from "@/i18n/config";
import { t } from "@/i18n/en";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { requireAuth } from "@/lib/auth";
import type { TaxonomyEntry } from "@/lib/taxonomy-match";

const lang = Astro.params.lang as string;
if (lang !== "es" && lang !== "en") {
  return Astro.redirect("/404");
}
const locale = lang as Locale;
const tr = t(locale);

const result = await requireAuth(Astro);
if (result instanceof Response) return result;
const { user } = result;

// supabase is guaranteed by requireAuth having succeeded above
// biome-ignore lint/style/noNonNullAssertion: requireAuth ensures supabase is defined
const supabase = Astro.locals.supabase!;

// Load all generations for the dropdown (anon-readable)
const { data: generations } = await supabase
  .from("generations")
  .select(
    "id, name_es, name_en, year_start, year_end, models!inner(slug, name_es, name_en, makes!inner(slug, name_es, name_en))"
  )
  .order("id");

type RawGen = {
  id: number;
  name_es: string;
  name_en: string;
  year_start: number;
  year_end: number | null;
  models: {
    slug: string;
    name_es: string;
    name_en: string;
    makes: { slug: string; name_es: string; name_en: string };
  };
};

type GenOption = {
  id: number;
  label: string;
};

const genOptions: GenOption[] = (generations ?? []).map((g) => {
  const gen = g as unknown as RawGen;
  const makeName = locale === "es" ? gen.models.makes.name_es : gen.models.makes.name_en;
  const modelName = locale === "es" ? gen.models.name_es : gen.models.name_en;
  const genName = locale === "es" ? gen.name_es : gen.name_en;
  const years = gen.year_end ? `${gen.year_start}–${gen.year_end}` : `${gen.year_start}–`;
  return { id: gen.id, label: `${makeName} ${modelName} ${genName} (${years})` };
});

// Build taxonomy for the OCR island (make+model names for fuzzy matching)
const ocrTaxonomy: TaxonomyEntry[] = (generations ?? []).map((g) => {
  const gen = g as unknown as RawGen;
  return {
    generation_id: gen.id,
    make_slug: gen.models.makes.slug,
    make_name: locale === "es" ? gen.models.makes.name_es : gen.models.makes.name_en,
    model_slug: gen.models.slug,
    model_name: locale === "es" ? gen.models.name_es : gen.models.name_en,
    gen_slug: gen.name_es.toLowerCase().replace(/\s+/g, "-"),
    gen_name: locale === "es" ? gen.name_es : gen.name_en,
    year_start: gen.year_start,
    year_end: gen.year_end,
  };
});

// Pre-resolved OCR island labels (no i18n logic inside the island)
const ocrLabels: Record<string, string> = {
  "garage.source.manual": tr("garage.source.manual"),
  "garage.source.ocr": tr("garage.source.ocr"),
  "garage.ocr.upload_label": tr("garage.ocr.upload_label"),
  "garage.ocr.upload_hint": tr("garage.ocr.upload_hint"),
  "garage.ocr.processing": tr("garage.ocr.processing"),
  "garage.ocr.no_match": tr("garage.ocr.no_match"),
  "garage.ocr.review_title": tr("garage.ocr.review_title"),
  "garage.ocr.confirm": tr("garage.ocr.confirm"),
  "garage.ocr.privacy_note": tr("garage.ocr.privacy_note"),
  "garage.ocr.field.marca": tr("garage.ocr.field.marca"),
  "garage.ocr.field.modelo": tr("garage.ocr.field.modelo"),
  "garage.ocr.field.ano": tr("garage.ocr.field.ano"),
  "garage.ocr.field.potencia": tr("garage.ocr.field.potencia"),
  "garage.ocr.field.cilindrada": tr("garage.ocr.field.cilindrada"),
  "garage.ocr.field.combustible": tr("garage.ocr.field.combustible"),
  "garage.ocr.km_label": tr("garage.ocr.km_label"),
  "garage.ocr.error_generic": tr("garage.ocr.error_generic"),
  "garage.ocr.error_consent_pii": tr("garage.ocr.error_consent_pii"),
  "garage.form.generation": tr("garage.form.generation"),
};

// Pre-fill from query param (from model detail page "Add to garage" button)
const preselectedGenId = Astro.url.searchParams.get("gen_id") ?? "";

let errorMsg: string | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const generationId = Number.parseInt(form.get("generation_id") as string, 10);
  const year = Number.parseInt(form.get("year") as string, 10);
  const km = form.get("km") ? Number.parseInt(form.get("km") as string, 10) : null;
  const purchasedAt = (form.get("purchased_at") as string | null) || null;
  const purchasePriceEur = form.get("purchase_price_eur")
    ? Number.parseFloat(form.get("purchase_price_eur") as string)
    : null;
  const notes = (form.get("notes") as string | null)?.trim() || null;

  if (!generationId || !year) {
    errorMsg =
      locale === "es" ? "Rellena los campos obligatorios." : "Fill in the required fields.";
  } else {
    const { error } = await supabase.from("user_cars").insert({
      user_id: user.id,
      generation_id: generationId,
      year,
      km,
      purchased_at: purchasedAt,
      purchase_price_eur: purchasePriceEur,
      notes,
    });

    if (error) {
      errorMsg = locale === "es" ? "No se pudo guardar el coche." : "Could not save the car.";
    } else {
      return Astro.redirect(`/${locale}/account/garage`);
    }
  }
}

const inputClass =
  "w-full rounded-[var(--radius)] border border-[var(--color-border)] bg-[var(--color-card)] px-3 py-2 text-sm text-[var(--color-fg)] placeholder:text-[var(--color-muted)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-ring)]";

const path = `/${locale}/account/garage/add`;
---

<BaseLayout title={tr("garage.add_title") + " | Jinba"} description={tr("garage.add_title")} locale={locale} path={path} noindex>
  <HomeNav locale={locale} />
  <main class="mx-auto max-w-lg px-4 py-12">
    <div class="mb-6">
      <a href={`/${locale}/account/garage`} class="mb-1 block text-sm text-[var(--color-muted)] hover:text-[var(--color-fg)]">
        &larr; {tr("garage.title")}
      </a>
      <h1 class="text-2xl font-bold">{tr("garage.add_title")}</h1>
    </div>

    {errorMsg && (
      <div role="alert" class="mb-6 rounded border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-400">
        {errorMsg}
      </div>
    )}

    <!-- Tab switcher: Manual | OCR -->
    <div class="mb-6" x-data="{ tab: 'manual' }">
      <!-- Tab buttons -->
      <div class="mb-5 flex gap-2 rounded-[var(--radius)] border border-[var(--color-border)] p-1" role="tablist">
        <button
          type="button"
          role="tab"
          id="tab-manual"
          aria-controls="panel-manual"
          class="tab-btn flex-1 rounded px-3 py-1.5 text-sm font-medium transition-colors data-[active]:bg-[var(--color-accent)] data-[active]:text-[var(--color-accent-fg)]"
          data-active
          onclick="switchTab('manual')"
        >
          {tr("garage.source.manual")}
        </button>
        <button
          type="button"
          role="tab"
          id="tab-ocr"
          aria-controls="panel-ocr"
          class="tab-btn flex-1 rounded px-3 py-1.5 text-sm font-medium transition-colors data-[active]:bg-[var(--color-accent)] data-[active]:text-[var(--color-accent-fg)]"
          onclick="switchTab('ocr')"
        >
          {tr("garage.source.ocr")}
        </button>
      </div>

      <!-- Manual tab panel -->
      <div id="panel-manual" role="tabpanel" aria-labelledby="tab-manual">
        <form method="POST" class="space-y-5">
          <div class="flex flex-col gap-1.5">
            <label for="generation_id" class="text-sm font-medium">{tr("garage.form.generation")}</label>
            <select id="generation_id" name="generation_id" required class={inputClass}>
              <option value="">—</option>
              {genOptions.map((g) => (
                <option value={g.id} selected={String(g.id) === preselectedGenId}>{g.label}</option>
              ))}
            </select>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="year" class="text-sm font-medium">{tr("garage.form.year")}</label>
            <input id="year" name="year" type="number" required min="1900" max={new Date().getFullYear()} class={inputClass} />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="km" class="text-sm font-medium">{tr("garage.form.km")}</label>
            <input id="km" name="km" type="number" min="0" class={inputClass} />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="purchased_at" class="text-sm font-medium">{tr("garage.form.purchased_at")}</label>
            <input id="purchased_at" name="purchased_at" type="date" class={inputClass} />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="purchase_price_eur" class="text-sm font-medium">{tr("garage.form.purchase_price")}</label>
            <input id="purchase_price_eur" name="purchase_price_eur" type="number" min="0" step="1" class={inputClass} />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="notes" class="text-sm font-medium">{tr("garage.form.notes")}</label>
            <textarea id="notes" name="notes" rows="3" class={inputClass}></textarea>
          </div>

          <button
            type="submit"
            class="w-full rounded-[var(--radius)] bg-[var(--color-accent)] px-4 py-2.5 text-sm font-semibold text-[var(--color-accent-fg)] transition-opacity hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-ring)]"
          >
            {tr("garage.form.submit")}
          </button>
        </form>
      </div>

      <!-- OCR tab panel -->
      <div id="panel-ocr" role="tabpanel" aria-labelledby="tab-ocr" hidden>
        <FichaTecnicaUpload
          client:only="react"
          locale={locale}
          taxonomy={ocrTaxonomy}
          addFormAction={`/${locale}/account/garage/add`}
          labels={ocrLabels}
        />
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  // Vanilla JS tab switcher — no framework, no alpine dependency
  function switchTab(name: string) {
    const panels = document.querySelectorAll("[role='tabpanel']");
    const buttons = document.querySelectorAll(".tab-btn");

    for (const panel of panels) {
      const el = panel as HTMLElement;
      el.hidden = el.id !== `panel-${name}`;
    }
    for (const btn of buttons) {
      const el = btn as HTMLButtonElement;
      if (el.id === `tab-${name}`) {
        el.dataset.active = "";
        el.setAttribute("aria-selected", "true");
      } else {
        delete el.dataset.active;
        el.setAttribute("aria-selected", "false");
      }
    }
  }

  // Export for onclick attributes
  (window as unknown as Record<string, unknown>).switchTab = switchTab;
</script>
