---
/**
 * src/pages/[lang]/guides/[slug].astro — M6 T14
 * Static guide detail. One page per (slug, locale) — 4 slugs × 2 locales = 8.
 * Uses Astro 6 `render(entry)` API (see M2 CRITICAL-01 fix).
 * REQ-ROUTE-02, REQ-ROUTE-03, REQ-DETAIL-01..05, REQ-SEO-01..03, REQ-JSONLD-01/02.
 */
import { type CollectionEntry, getCollection, render } from "astro:content";
import GuideHero from "@/components/guides/GuideHero.astro";
import HomeFooter from "@/components/home/HomeFooter.astro";
import HomeNav from "@/components/home/HomeNav.astro";
import TocSidebar from "@/components/model/TocSidebar.astro";
import TocSidebarMobile from "@/components/model/TocSidebarMobile.tsx";
import type { Locale } from "@/i18n/config";
import { t } from "@/i18n/en";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { buildArticleJsonLd } from "@/lib/jsonld";
import { computeReadingTime, extractHeadings, guideSlug } from "@/lib/reading-time";

export async function getStaticPaths() {
  const all = await getCollection("guides");
  return all.map((entry) => ({
    params: {
      lang: entry.data.locale,
      slug: guideSlug(entry.id, entry.data.locale),
    },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"guides"> };
const lang = entry.data.locale as Locale;
const tr = t(lang);

const slug = guideSlug(entry.id, entry.data.locale);
const path = `/${lang}/guides/${slug}/`;

const { Content } = await render(entry);

const bodySource = entry.body ?? "";
const headings = extractHeadings(bodySource);
const minutes = computeReadingTime(bodySource, entry.data.reading_time_min);

const tocSections =
  headings.length > 0 ? headings : [{ id: "content", title: tr("guides.detail.tocHeading") }];

const site = (import.meta.env.PUBLIC_SITE_URL as string | undefined) ?? "https://jinba.example.com";
const url = new URL(path, site).toString();

const cover = entry.data.cover_image ?? entry.data.cover;
const image = cover
  ? new URL(cover, site).toString()
  : new URL("/placeholders/home-hero.webp", site).toString();

const jsonLd = buildArticleJsonLd({
  title: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.publishedAt.toISOString(),
  dateModified: entry.data.updatedAt?.toISOString(),
  author: entry.data.author,
  image,
  url,
  locale: lang,
  siteOrgId: `${site}#organization`,
});
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  locale={lang}
  path={path}
  image={image}
  serif={true}
  jsonLd={jsonLd}
>
  {
    entry.data.author && (
      <Fragment slot="head">
        <meta name="author" content={entry.data.author} />
      </Fragment>
    )
  }

  <a
    href="#guide-main"
    class="sr-only focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-20 focus:rounded-[var(--radius-sm)] focus:border focus:border-[var(--color-border)] focus:bg-[var(--color-card)] focus:px-3 focus:py-2 focus:text-sm focus:text-[var(--color-fg)]"
  >
    {tr("guides.detail.skipToContent")}
  </a>

  <HomeNav locale={lang} />

  <main id="guide-main" class="mx-auto max-w-6xl px-4 pb-16">
    <nav aria-label="breadcrumb" class="py-4 text-sm text-[var(--color-muted)]">
      <ol class="flex flex-wrap items-center gap-1">
        <li>
          <a
            href={`/${lang}/`}
            class="hover:text-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
          >
            {tr("nav.home")}
          </a>
        </li>
        <li aria-hidden="true">›</li>
        <li>
          <a
            href={`/${lang}/guides/`}
            class="hover:text-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
          >
            {tr("nav.guides")}
          </a>
        </li>
        <li aria-hidden="true">›</li>
        <li><span aria-current="page">{entry.data.title}</span></li>
      </ol>
    </nav>

    <GuideHero entry={entry} locale={lang} minutes={minutes} />

    <div class="mt-8 grid gap-8 lg:grid-cols-[18rem_minmax(0,1fr)]">
      <aside class="hidden lg:block">
        <TocSidebar sections={tocSections} locale={lang} />
      </aside>

      <div class="lg:hidden">
        <TocSidebarMobile
          client:idle
          sections={tocSections}
          labels={{ open: tr("model.toc.open"), close: tr("model.toc.close") }}
        />
      </div>

      <article class="prose prose-invert max-w-none lg:col-start-2">
        {
          headings.length === 0 ? (
            <section id="content">
              <Content />
            </section>
          ) : (
            <Content />
          )
        }

        <p class="mt-10 text-sm">
          <a
            href={`/${lang}/guides/`}
            class="text-[var(--color-accent)] underline underline-offset-2 hover:text-[var(--color-fg)] focus-visible:outline-2 focus-visible:outline-[var(--color-ring)]"
          >
            ← {tr("guides.detail.backToIndex")}
          </a>
        </p>
      </article>
    </div>
  </main>

  <HomeFooter locale={lang} />
</BaseLayout>
